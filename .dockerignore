# Exclude docker/ to avoid setuptools "Multiple top-level packages" error
# (docker + evennia would both be discovered; script lives in bin/unix/)
docker/

# Exclude game/ - auto-created at runtime, not part of the Evennia package
game/

# Exclude batch_imps - game data, not part of Evennia; available at runtime via volume
batch_imps/

# Exclude postgres_data - database files, not part of Evennia
postgres_data/

# Exclude frontend/ - separate Next.js app, not part of Evennia package
frontend/

# Exclude deploy/ - KVM / multi-host layout notes only; not part of the Evennia runtime
deploy/

# Python caches (often root-owned on host after bind-mount runs); not needed in image and
# can make "load build context" fail for the unprivileged context sender.
**/__pycache__/
**/*.py[cod]
**/*.pyo
