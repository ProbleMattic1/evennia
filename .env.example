# Docker Compose environment overrides
# Copy to .env and adjust as needed

# PostgreSQL credentials (must match postgres service)
POSTGRES_PASSWORD=password

# Evennia superuser (created on first run when DB is empty)
# EVENNIA_SUPERUSER_USERNAME=admin
# EVENNIA_SUPERUSER_PASSWORD=admin
# EVENNIA_SUPERUSER_EMAIL=

# User ID for file ownership (Linux/Mac: run `echo $UID:$GID`)
# Uncomment and set in docker-compose.yml under evennia service:
# user: "1000:1000"

# Optional: reduce autonomous hauler load in local dev (Evennia container env).
# AURNOM_HAULER_ENGINE_INTERVAL_SEC=600
# AURNOM_MAX_HAULERS_PER_ENGINE_TICK=50
# AURNOM_HAULER_MAX_PIPELINE_STEPS=8
# Per-step hauler messages use logger "hauler_engine.steps" at DEBUG if you need them.
