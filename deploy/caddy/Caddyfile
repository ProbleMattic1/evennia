# Single browser entrypoint — http://localhost:8080 (see game/docs/WEB_PLATFORM_EDGE.md)
# Next upstream: default compose service "frontend"; dev overlay may set CADDY_UPSTREAM_NEXT=frontend_dev:3000

:8080 {
	reverse_proxy /api* {$CADDY_UPSTREAM_NEXT:frontend:3000}
	reverse_proxy /auth* evennia:4001
	reverse_proxy /webclient* evennia:4001
	reverse_proxy /media* evennia:4001
	reverse_proxy /static* evennia:4001
	reverse_proxy /admin* evennia:4001
	reverse_proxy /favicon.ico evennia:4001
	reverse_proxy {$CADDY_UPSTREAM_NEXT:frontend:3000}
}
