# Copy to .env on KVM 2. Never commit.

# Your public domain (used by Caddy for TLS + virtual hosting)
DOMAIN=game.yourdomain.com

# Registry images — updated by CI on each release
FRONTEND_IMAGE=ghcr.io/yourorg/aurnom-web
IMAGE_TAG=latest

# KVM 4 private IP — used by Caddy to proxy API/WS and by Next for SSR API calls
EVENNIA_HOST=10.0.0.Y
EVENNIA_BASE_URL=http://10.0.0.Y:4001
