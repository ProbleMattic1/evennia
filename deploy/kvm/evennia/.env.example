# Copy to .env on KVM 4. Never commit.

# Registry image — match CI push target (e.g. ghcr.io/yourorg/aurnom-evennia)
REGISTRY_IMAGE=ghcr.io/yourorg/aurnom-evennia
IMAGE_TAG=latest

# Private IP of KVM 8 — the host-level private network address, not a Docker alias.
POSTGRES_HOST=10.0.0.X
POSTGRES_DB=evennia
POSTGRES_USER=evennia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# Superuser (set once; ignored after first migration/init)
EVENNIA_SUPERUSER_USERNAME=admin
EVENNIA_SUPERUSER_PASSWORD=CHANGE_ME
EVENNIA_SUPERUSER_EMAIL=

# Interface to bind game ports on — use the KVM 4 private IP so only KVM 2 can reach it.
BIND_HOST=10.0.0.Y
