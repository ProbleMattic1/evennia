# Copy to .env on KVM 1. Never commit.

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# KVM 8 DB connection — used by the backup container
POSTGRES_HOST=10.0.0.X
POSTGRES_USER=evennia
POSTGRES_DB=evennia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Local directory to stage backup dumps before offsite sync
BACKUP_STAGING_DIR=./backups
